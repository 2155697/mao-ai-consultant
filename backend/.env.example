# LLM API配置（支持OpenAI兼容格式）
MAO_API_KEY=
MAO_BASE_URL=https://api.moonshot.cn/v1
MAO_MODEL=kimi-k2.6
MAO_TEMPERATURE=1.0
MAO_MAX_TOKENS=4096

# Mock模式（无API Key时使用模拟响应）
MAO_MOCK_MODE=false

# 引擎参数
MAO_RAG_TOP_K=5
MAO_SIGNATURE_THRESHOLD=0.15
MAO_MAX_PROMPT_LENGTH=3500

# 服务配置
MAO_HOST=0.0.0.0
MAO_PORT=8000
